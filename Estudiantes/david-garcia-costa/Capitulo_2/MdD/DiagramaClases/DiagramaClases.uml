@startuml

package "Sistema" {

class Usuario {
  +idUsuario: String
  +nombreUsuario: String
  +email: String
  +rol: String
  +fechaRegistro: Date
}

class SesionTrabajo {
  +idSesion: String
  +nombre: String
  +descripcion: Text
  +projectName: String
  +modoTrabajo: String
  +estado: String
  +pasoActual: Integer
  +fechaCreacion: Date
  +fechaActualizacion: Date
}

class Documentacion {
  +idDocumentacion: String
  +tipoEntrada: String
  +contenido: Text
  +referencia: String
  +fechaRegistro: Date
}

class CasoDeUso {
  +idUC: String
  +nombre: String
  +descripcion: Text
  +trazabilidadLiteral: Text
  +estado: String
  +version: Integer
}

class RequisitoFuncional {
  +idRF: String
  +descripcion: Text
  +trazabilidadLiteral: Text
  +estado: String
  +version: Integer
}

class EscenarioGherkin {
  +idEscenario: String
  +titulo: String
  +given: Text
  +when: Text
  +then: Text
}

class Borrador {
  +idBorrador: String
  +resumen: String
  +categoria: String
  +gherkinText: Text
  +estado: String
  +versionActual: Integer
  +feedback: List
  +fechaCreacion: Date
  +fechaActualizacion: Date
  +projectName: String
  +sourceDocuments: List
}

class CasoPrueba {
  +idCaso: String
  +summary: String
  +texto: Text
  +categoria: String
  +prioridad: String
  +estado: String
}

Usuario  ->  SesionTrabajo : crea / gestiona
SesionTrabajo  o--  Documentacion : agrupa
SesionTrabajo  o--  CasoDeUso : agrupa
SesionTrabajo  o--  RequisitoFuncional : agrupa
SesionTrabajo  o--  EscenarioGherkin : agrupa
SesionTrabajo  o--  Borrador : contiene

Documentacion  o-- CasoDeUso
Documentacion  o--  RequisitoFuncional

CasoDeUso  --  RequisitoFuncional : traza

EscenarioGherkin  -->  CasoDeUso : cubre / traza
EscenarioGherkin --> RequisitoFuncional : cubre / traza

Borrador  o--  EscenarioGherkin : contiene

CasoPrueba  -->  Borrador : deriva de
}

class KiwiTCMS <<externo>>

CasoPrueba  --> KiwiTCMS : registrar

@enduml
